# ВАЖНО: не оставляй inline-комментарии (KEY=value  # ...) — docker compose env_file
# не срезает их у значения и они утекут в переменную. Комментарии — только на своих строках.

# Discord bot
DISCORD_BOT_TOKEN=

# Discord OAuth (IdP)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# публичный https callback
OAUTH_REDIRECT_URI=
# публичный https корень сервера (для MCP resource metadata)
PUBLIC_BASE_URL=

# Cloudflare Tunnel: токен из CF Zero Trust (Networks -> Tunnels).
# Ingress (hostname -> http://app:3000) настраивается в дашборде туннеля.
TUNNEL_TOKEN=

# HTTP
PORT=3000

# DB
DB_PATH=./data/guild-mcp.db
