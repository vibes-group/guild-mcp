# Справка: содержимое /opt/guild-mcp/.env (пишется workflow'ом из секретов).

IMAGE_TAG=<github commit sha>
DISCORD_BOT_TOKEN=<discord bot token>
DISCORD_CLIENT_ID=<discord oauth client id>
DISCORD_CLIENT_SECRET=<discord oauth client secret>
OAUTH_REDIRECT_URI=<публичный https callback>
PUBLIC_BASE_URL=<публичный https корень сервера>
TUNNEL_TOKEN=<cloudflare tunnel token>
PORT=3000
DB_PATH=./data/guild-mcp.db
